# ============================================================
# Bitbucket Cloud Authentication — choose ONE method
# ============================================================

# METHOD 1 — API Token (recommended)
# Create at: https://id.atlassian.com/manage-profile/security/api-tokens
# Use your Atlassian account email + the generated token.
BITBUCKET_EMAIL=you@example.com
BITBUCKET_API_TOKEN=your_api_token

# METHOD 2 — App Password (legacy, still supported)
# Create at: https://bitbucket.org/account/settings/app-passwords/
# BITBUCKET_USERNAME=your_bitbucket_username
# BITBUCKET_APP_PASSWORD=your_app_password

# ============================================================
# Optional
# ============================================================
LOG_LEVEL=info
